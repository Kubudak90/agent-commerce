# Get an API key by running:  npx @arcora/agent-commerce onboard
ARCORA_API_KEY=ak_live_your_secret_key_here
ARCORA_BASE_URL=https://arcorapay.xyz

# Optional — only needed to enable the `refund_invoice` MCP tool / `refund` CLI command.
# This is the merchant signing wallet's private key; `serve` reads it (env wins over
# the keyfile at ~/.arcora/merchant.key). NEVER commit a real key.
# ARCORA_MERCHANT_KEY=0xyour_merchant_private_key
