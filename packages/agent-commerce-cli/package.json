{
  "name": "@arcora/agent-commerce",
  "version": "0.1.2",
  "description": "One command to turn an AI agent into an Arcorapay merchant, plus an MCP server it serves — sell from a catalog and invoice in USDC, payable cross-chain from Base.",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/Kubudak90/agent-commerce.git", "directory": "packages/agent-commerce-cli" },
  "homepage": "https://github.com/Kubudak90/agent-commerce#readme",
  "bugs": "https://github.com/Kubudak90/agent-commerce/issues",
  "keywords": ["arcorapay", "mcp", "ai-agent", "usdc", "stablecoin", "payments", "crosschain"],
  "type": "module",
  "bin": { "arcora-agent-commerce": "./dist/cli.js" },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "onboard": "tsx src/cli.ts onboard",
    "serve": "tsx src/cli.ts serve",
    "build": "pnpm --filter @arcora/sdk build && tsup",
    "test": "pnpm --filter @arcora/sdk build && vitest run",
    "typecheck": "pnpm --filter @arcora/sdk build && tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "siwe": "^3.0.0",
    "viem": "^2.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@arcora/agent-commerce-core": "workspace:*",
    "@arcora/agent-commerce-mcp": "workspace:*",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
